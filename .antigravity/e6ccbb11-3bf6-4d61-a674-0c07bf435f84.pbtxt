  file_change {
    absolute_path_uri: "file:///src/components/CartScreen.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\nimport { \n  ArrowLeft, \n  MapPin, \n  CreditCard, \n  Wallet, \n  Trash2, \n  Plus, \n  Minus, \n  Check, \n  ShoppingBag, \n  Clock, \n  AlertCircle \n} from \'lucide-react\';\nimport { CartItem } from \'../types\';\n\ninterface CartScreenProps {\n  cartItems: CartItem[];\n  onUpdateQuantity: (id: string, delta: number) => void;\n  onRemoveItem: (id: string) => void;\n  onPlaceOrder: (paymentMethod: string, address: string, deliveryFee: number) => void;\n  onScreenChange: (screen: \'home\' | \'cart\' | \'tracking\') => void;\n}\n\nexport default function CartScreen({\n  cartItems,\n  onUpdateQuantity,\n  onRemoveItem,\n  onPlaceOrder,\n  onScreenChange\n}: CartScreenProps) {\n  const [paymentMethod, setPaymentMethod] = useState<\'stripe\' | \'razorpay\'>(\'stripe\');\n  const [selectedAddress, setSelectedAddress] = useState(\'4522 Business District, Skyline Towers, Apt 4B\');\n  const [editingAddress, setEditingAddress] = useState(false);\n  const [tempAddress, setTempAddress] = useState(selectedAddress);\n\n  const [savingOrder, setSavingOrder] = useState(false);\n\n  // Subtotal calculation\n  const subtotal = cartItems.reduce((acc, c) => acc + (c.menuItem.price * c.quantity), 0);\n  \n  // Delivery fee based on items\' restaurants\n  const deliveryFee = cartItems.length > 0 ? 2.99 : 0;\n  \n  // Taxes and charges (estimated)\n  const taxesAndCharges = cartItems.length > 0 ? 1.45 : 0;\n  \n  // Total\n  const total = subtotal + deliveryFee + taxesAndCharges;\n\n  const handlePlaceOrder = () => {\n    if (cartItems.length === 0) return;\n    setSavingOrder(true);\n    \n    // Simulate payment processing loader\n    setTimeout(() => {\n      onPlaceOrder(\n        paymentMethod === \'stripe\' ? \'Credit/Debit Card (Stripe)\' : \'UPI / Wallet (Razorpay)\',\n        selectedAddress,\n        deliveryFee\n      );\n      setSavingOrder(false);\n    }, 1500);\n  };\n\n  const saveAddress = () => {\n    setSelectedAddress(tempAddress);\n    setEditingAddress(false);\n  };\n\n  return (\n    <div className=\"max-w-[1280px] mx-auto px-6 md:px-10 py-6 md:py-10 grid grid-cols-1 lg:grid-cols-12 gap-10 font-sans\">\n      \n      {/* Return link */}\n      <div className=\"col-span-12 flex items-center gap-4\">\n        <button \n          onClick={() => onScreenChange(\'home\')}\n          className=\"p-2.5 rounded-full border border-gray-200 hover:bg-[#f5f3f3] transition-colors active:scale-90\"\n        >\n          <ArrowLeft className=\"h-5 w-5 text-[#a83300]\" />\n        </button>\n        <div>\n          <h1 className=\"text-xl md:text-2xl font-extrabold text-[#1b1c1c] tracking-tight\">Your Basket</h1>\n          <p className=\"text-xs text-gray-500 mt-0.5\">Edit items, select payment options, and complete order</p>\n        </div>\n      </div>\n\n      {emptyStateView()}\n\n      {/* LEFT COLUMN: Food Basket & Address & Payment */}\n      {cartItems.length > 0 && (\n        <div className=\"lg:col-span-7 flex flex-col gap-8\">\n          \n          {/* ITEMS CONTAINER */}\n          <section className=\"bg-white rounded-2xl border border-gray-200 p-5 shadow-xs flex flex-col gap-4\">\n            <div className=\"flex justify-between items-center border-b border-gray-100 pb-3\">\n              <h2 className=\"text-sm font-bold text-gray-400 uppercase tracking-widest\">Added Dishes ({cartItems.length})</h2>\n              <button \n                onClick={() => onScreenChange(\'home\')}\n                className=\"text-xs text-[#a83300] font-bold hover:underline\"\n              >\n                + Add more foods\n              </button>\n            </div>\n\n            <div className=\"divide-y divide-gray-100\">\n              {cartItems.map((item) => (\n                <div key={item.id} className=\"py-4 flex gap-4 items-center\">\n                  {/* Food Cover preview */}\n                  {item.menuItem.image ? (\n                    <img \n                      src={item.menuItem.image} \n                      alt={item.menuItem.name} \n                      className=\"w-16 h-16 rounded-xl object-cover border border-gray-100 shrink-0\"\n                      referrerPolicy=\"no-referrer\" \n                    />\n                  ) : (\n                    <div className=\"w-16 h-16 rounded-xl bg-[#ffdbd0] flex items-center justify-center text-[#a83300] font-bold shrink-0\">\n                      \360\237\215\224\n                    </div>\n                  )}\n\n                  <div className=\"flex-1 flex flex-col justify-between h-16 py-0.5\">\n                    <div>\n                      <h3 className=\"font-bold text-sm text-[#1b1c1c]\">{item.menuItem.name}</h3>\n                      <p className=\"text-[10px] text-gray-400 font-semibold uppercase tracking-wider mt-0.5\">\n                        {item.restaurantName} {item.customization ? `\342\200\242 Customized: ${item.customization}` : \'\'}\n                      </p>\n                    </div>\n\n                    <div className=\"flex items-center justify-between\">\n                      <span className=\"text-[#a83300] font-extrabold text-sm\">\n                        ${(item.menuItem.price * item.quantity).toFixed(2)}\n                      </span>\n\n                      {/* Quantity trigger */}\n                      <div className=\"flex items-center bg-[#f5f3f3] rounded-full px-2 py-1.5 border border-gray-200/50\">\n                        <button \n                          onClick={() => onUpdateQuantity(item.id, -1)}\n                          className=\"w-6 h-6 flex items-center justify-center hover:bg-white rounded-full transition-all active:scale-90 text-gray-700\"\n                        >\n                          <Minus className=\"h-3.5 w-3.5\" />\n                        </button>\n                        <span className=\"mx-3 text-xs font-bold font-sans text-gray-800\">\n                          {item.quantity}\n                        </span>\n                        <button \n                          onClick={() => onUpdateQuantity(item.id, 1)}\n                          className=\"w-6 h-6 flex items-center justify-center hover:bg-white rounded-full transition-all active:scale-90 text-gray-700\"\n                        >\n                          <Plus className=\"h-3.5 w-3.5\" />\n                        </button>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Remove Button */}\n                  <button \n                    onClick={() => onRemoveItem(item.id)}\n                    className=\"p-2 text-gray-400 hover:text-red-500 rounded-full hover:bg-red-50 transition-colors\"\n                  >\n                    <Trash2 className=\"h-4 w-4\" />\n                  </button>\n                </div>\n              ))}\n            </div>\n          </section>\n\n          {/* DELIVERY ADDRESS */}\n          <section className=\"bg-white rounded-2xl border border-gray-200 p-5 shadow-xs\">\n            <div className=\"flex justify-between items-center mb-4\">\n              <h2 className=\"text-xs font-bold text-gray-400 uppercase tracking-widest\">Delivery Address</h2>\n              {!editingAddress && (\n                <button \n                  onClick={() => setEditingAddress(true)}\n                  className=\"text-xs text-[#a83300] font-bold\"\n                >\n                  Change\n                </button>\n              )}\n            </div>\n\n            {editingAddress ? (\n              <div className=\"flex flex-col gap-3\">\n                <input \n                  type=\"text\"\n                  className=\"bg-[#f5f3f3] border-none focus:ring-2 focus:ring-[#a83300] outline-none text-sm p-3.5 rounded-xl text-gray-800\"\n                  value={tempAddress}\n                  onChange={(e) => setTempAddress(e.target.value)}\n                />\n                <div className=\"flex gap-2 self-end\">\n                  <button \n                    onClick={() => setEditingAddress(false)}\n                    className=\"px-4 py-1.5 rounded-lg border border-gray-200 text-xs font-semibold hover:bg-gray-50 text-gray-600\"\n                  >\n                    Cancel\n                  </button>\n                  <button \n                    onClick={saveAddress}\n                    className=\"px-4 py-1.5 rounded-lg bg-[#a83300] text-white text-xs font-bold hover:bg-[#d24200]\"\n                  >\n                    Save Address\n                  </button>\n                </div>\n              </div>\n            ) : (\n              <div className=\"flex gap-4 items-center bg-[#f5f3f3]/40 border border-gray-100 p-4 rounded-xl\">\n                <div className=\"w-10 h-10 rounded-full bg-[#ffdbd0] flex items-center justify-center shrink-0\">\n                  <MapPin className=\"h-5 w-5 text-[#a83300]\" />\n                </div>\n                <div className=\"flex-1 min-w-0\">\n                  <h4 className=\"font-bold text-sm text-[#1b1c1c]\">Home Address</h4>\n                  <p className=\"text-xs text-gray-500 truncate mt-0.5\">{selectedAddress}</p>\n                </div>\n              </div>\n            )}\n          </section>\n\n          {/* PAYMENT METHOD CHOICE */}\n          <section className=\"bg-white rounded-2xl border border-gray-200 p-5 shadow-xs\">\n            <h2 className=\"text-xs font-bold text-gray-400 uppercase tracking-widest mb-4\">Payment Method</h2>\n            \n            <div className=\"flex flex-col gap-3\">\n              {/* Card - Default option */}\n              <label \n                className={`flex items-center p-4 rounded-xl cursor-pointer transition-all border ${paymentMethod === \'stripe\' ? \'border-[#a83300] bg-[#ffdbd0]/20 shadow-xs\' : \'border-gray-200 hover:bg-gray-50\'}`}\n              >\n                <input \n                  type=\"radio\" \n                  name=\"payment\" \n                  checked={paymentMethod === \'stripe\'}\n                  onChange={() => setPaymentMethod(\'stripe\')}\n                  className=\"hidden\"\n                />\n                <div className=\"w-10 h-10 rounded-lg bg-[#635BFF]/10 flex items-center justify-center shrink-0\">\n                  <CreditCard className=\"h-5 w-5 text-[#635BFF]\" />\n                </div>\n                <div className=\"ml-4 flex-1\">\n                  <span className=\"block font-bold text-sm text-[#1b1c1c]\">Credit / Debit Card</span>\n                  <span className=\"block text-xs text-gray-500 mt-0.5\">Stripe Secure Payment Portal</span>\n                </div>\n                <div className={`w-5 h-5 rounded-full border-2 flex items-center justify-center ${paymentMethod === \'stripe\' ? \'border-[#a83300]\' : \'border-gray-300\'}`}>\n                  {paymentMethod === \'stripe\' && <div className=\"w-2.5 h-2.5 rounded-full bg-[#a83300]\" />}\n                </div>\n              </label>\n\n              {/* UPI - Alternative option */}\n              <label \n                className={`flex items-center p-4 rounded-xl cursor-pointer transition-all border ${paymentMethod === \'razorpay\' ? \'border-[#a83300] bg-[#ffdbd0]/20 shadow-xs\' : \'border-gray-200 hover:bg-gray-50\'}`}\n              >\n                <input \n                  type=\"radio\" \n                  name=\"payment\" \n                  checked={paymentMethod === \'razorpay\'}\n                  onChange={() => setPaymentMethod(\'razorpay\')}\n                  className=\"hidden\"\n                />\n                <div className=\"w-10 h-10 rounded-lg bg-[#3395FF]/10 flex items-center justify-center shrink-0\">\n                  <Wallet className=\"h-5 w-5 text-[#3395FF]\" />\n                </div>\n                <div className=\"ml-4 flex-1\">\n                  <span className=\"block font-bold text-sm text-[#1b1c1c]\">Razorpay / UPI Wallet</span>\n                  <span className=\"block text-xs text-gray-500 mt-0.5\">Fast instant checkout with direct UPI</span>\n                </div>\n                <div className={`w-5 h-5 rounded-full border-2 flex items-center justify-center ${paymentMethod === \'razorpay\' ? \'border-[#a83300]\' : \'border-gray-300\'}`}>\n                  {paymentMethod === \'razorpay\' && <div className=\"w-2.5 h-2.5 rounded-full bg-[#a83300]\" />}\n                </div>\n              </label>\n            </div>\n          </section>\n        </div>\n      )}\n\n      {/* RIGHT COLUMN: Bill Calculations & Checkout Button */}\n      {cartItems.length > 0 && (\n        <div className=\"lg:col-span-5 flex flex-col gap-6\">\n          <section className=\"bg-white rounded-2xl border border-gray-200 p-6 shadow-md sticky top-24\">\n            <h2 className=\"text-sm font-bold text-[#1b1c1c] tracking-tight mb-5 border-b border-gray-100 pb-3\">\n              Bill Summary\n            </h2>\n\n            <div className=\"space-y-4 text-sm font-sans font-medium text-gray-650\">\n              <div className=\"flex justify-between items-center text-gray-650\">\n                <span>Subtotal</span>\n                <span className=\"font-bold text-gray-800\">${subtotal.toFixed(2)}</span>\n              </div>\n              <div className=\"flex justify-between items-center\">\n                <span>Delivery Fee</span>\n                <span className=\"font-bold text-gray-800\">${deliveryFee.toFixed(2)}</span>\n              </div>\n              <div className=\"flex justify-between items-center\">\n                <span>Taxes &amp; Service Charges</span>\n                <span className=\"font-bold text-gray-800\">${taxesAndCharges.toFixed(2)}</span>\n              </div>\n\n              <div className=\"h-px bg-gray-100 my-4\"></div>\n\n              <div className=\"flex justify-between items-center text-[#1b1c1c] pt-2\">\n                <span className=\"text-base font-extrabold\">Final Grand Total</span>\n                <span className=\"text-xl font-black text-[#a83300]\">${total.toFixed(2)}</span>\n              </div>\n            </div>\n\n            {/* Simulated voucher text */}\n            <div className=\"mt-6 flex gap-3 bg-[#00c853]/10 p-3.5 rounded-xl items-center border border-[#00c853]/20\">\n              <Check className=\"h-5 w-5 text-[#00c853] shrink-0\" />\n              <p className=\"text-xs text-[#00c853] font-bold font-sans\">\n                You saved $4.50 in delivery discount on this purchase!\n              </p>\n            </div>\n\n            {/* Place Order CTA Button */}\n            <button \n              onClick={handlePlaceOrder}\n              disabled={savingOrder}\n              className=\"mt-6 w-full h-14 bg-[#d24200] hover:bg-[#a83300] text-white rounded-xl flex items-center justify-between px-6 font-bold tracking-wide active:scale-[0.98] transition-all shadow-md shadow-[#d24200]/25 disabled:opacity-75 disabled:pointer-events-none\"\n            >\n              <span>{savingOrder ? \'Locking Payment Securely...\' : \'PLACE ORDER\'}</span>\n              <div className=\"flex items-center gap-2\">\n                <span className=\"h-6 w-[1.5px] bg-white/20\"></span>\n                <span>${total.toFixed(2)}</span>\n              </div>\n            </button>\n          </section>\n        </div>\n      )}\n    </div>\n  );\n\n  function emptyStateView() {\n    if (cartItems.length > 0) return null;\n    return (\n      <div className=\"col-span-12 py-16 text-center flex flex-col items-center justify-center gap-6 bg-white rounded-2xl border border-gray-150\">\n        <div className=\"w-20 h-20 bg-[#ffdbd0] rounded-full flex items-center justify-center animate-bounce text-3xl\">\n          \360\237\215\261\n        </div>\n        <div>\n          <h2 className=\"text-xl font-bold text-gray-800\">Your Basket is Empty</h2>\n          <p className=\"text-xs text-gray-500 mt-2 max-w-sm mx-auto leading-relaxed\">\n            Fill your basket with delicious foods, fresh groceries, and sweet delights from top Manhattan restaurants.\n          </p>\n        </div>\n        <button \n          onClick={() => onScreenChange(\'home\')}\n          className=\"bg-[#a83300] hover:bg-[#d24200] text-white text-xs font-bold px-8 py-3 rounded-full flex items-center gap-2 shadow-md active:scale-95 transition-all\"\n        >\n          <ShoppingBag className=\"h-4 w-4\" />\n          <span>Browse Restaurants</span>\n        </button>\n      </div>\n    );\n  }\n}\n"
    }
