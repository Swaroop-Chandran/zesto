        }
        lines {
          text: "import React, { useState, useRef, useMemo } from \'react\';"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "import { "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
