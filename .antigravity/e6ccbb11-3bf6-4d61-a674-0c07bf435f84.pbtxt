      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useRef, useMemo } from \'react\';\nimport { \n  ChevronLeft, \n  ChevronRight, \n  Star, \n  Clock, \n  MapPin, \n  Sparkles, \n  SlidersHorizontal, \n  ArrowUpDown, \n  ShoppingBag, \n  Plus, \n  Minus, \n  X, \n  Check, \n  AlertCircle \n} from \'lucide-react\';\nimport { CATEGORIES, RECENTS, RESTAURANTS } from \'../data\';\nimport { Restaurant, MenuItem, CartItem } from \'../types\';\n\ninterface CustomerHomeProps {\n  onAddToCart: (item: MenuItem, restaurant: Restaurant, custom?: string) => void;\n  onScreenChange: (screen: \'home\' | \'cart\' | \'tracking\') => void;\n  cartCount: number;\n  searchValue: string;\n}\n\nexport default function CustomerHome({\n  onAddToCart,\n  onScreenChange,\n  cartCount,\n  searchValue\n}: CustomerHomeProps) {\n  const [selectedCategory, setSelectedCategory] = useState<string | null>(null);\n  const [selectedRestaurant, setSelectedRestaurant] = useState<Restaurant | null>(null);\n  const [menuModalOpen, setMenuModalOpen] = useState(false);\n  const [claimedOffer, setClaimedOffer] = useState(false);\n  const [sortBy, setSortBy] = useState<\'rating\' | \'time\' | \'distance\' | \'none\'>(\'none\');\n  const [filterFreeDelivery, setFilterFreeDelivery] = useState(false);\n  const [showFiltersDropdown, setShowFiltersDropdown] = useState(false);\n  const [toastMessage, setToastMessage] = useState<string | null>(null);\n\n  // Customization state inside Menu Modal\n  const [activeCustomization, setActiveCustomization] = useState<string>(\'\');\n\n  const scrollContainerRef = useRef<HTMLDivElement>(null);\n\n  const displayToast = (msg: string) => {\n    setToastMessage(msg);\n    setTimeout(() => setToastMessage(null), 3000);\n  };\n\n  const handleScroll = (direction: \'left\' | \'right\') => {\n    if (scrollContainerRef.current) {\n      const scrollAmount = 300;\n      scrollContainerRef.current.scrollBy({\n        left: direction === \'left\' ? -scrollAmount : scrollAmount,\n        behavior: \'smooth\'\n      });\n    }\n  };\n\n  const selectRestaurant = (res: Restaurant) => {\n    setSelectedRestaurant(res);\n    setMenuModalOpen(true);\n    setActiveCustomization(\'\');\n  };\n\n  const handleClaimOffer = () => {\n    setClaimedOffer(true);\n    displayToast(\'\360\237\216\211 50% discount coupon applied successfully to your cart!\');\n  };\n\n  const handleReorder = (recent: typeof RECENTS[0]) => {\n    const parentRest = RESTAURANTS.find(r => r.id === recent.restaurantId) || RESTAURANTS[0];\n    onAddToCart(recent.menuItem, parentRest, \'Reordered\');\n    displayToast(`Added ${recent.dishName} from ${recent.restaurantName} directly to your cart!`);\n  };\n\n  // Process data with filtering and sorting\n  const processedRestaurants = useMemo(() => {\n    let result = [...RESTAURANTS];\n\n    // Filter by Search Query\n    if (searchValue.trim().length > 0) {\n      const query = searchValue.toLowerCase();\n      result = result.filter(res => \n        res.name.toLowerCase().includes(query) ||\n        res.tags.some(tag => tag.toLowerCase().includes(query)) ||\n        res.menu.some(item => item.name.toLowerCase().includes(query))\n      );\n    }\n\n    // Filter by active category\n    if (selectedCategory) {\n      result = result.filter(res => \n        res.tags.some(tag => tag.toLowerCase().includes(selectedCategory.toLowerCase())) ||\n        res.menu.some(item => item.name.toLowerCase().includes(selectedCategory.toLowerCase()))\n      );\n    }\n\n    // Filter by Free Delivery\n    if (filterFreeDelivery) {\n      result = result.filter(res => res.isFreeDelivery);\n    }\n\n    // Sorting\n    if (sortBy === \'rating\') {\n      result.sort((a, b) => b.rating - a.rating);\n    } else if (sortBy === \'time\') {\n      result.sort((a, b) => a.deliveryTimeValue - b.deliveryTimeValue);\n    } else if (sortBy === \'distance\') {\n      result.sort((a, b) => a.distance - b.distance);\n    }\n\n    return result;\n  }, [searchValue, selectedCategory, filterFreeDelivery, sortBy]);\n\n  return (\n    <div className=\"relative font-sans text-[#1b1c1c] max-w-[1280px] mx-auto px-6 md:px-10 py-6 md:py-10 flex flex-col gap-10 md:gap-14\">\n      \n      {/* Dynamic Toast Prompt */}\n      {toastMessage && (\n        <div className=\"fixed bottom-6 right-6 md:bottom-10 md:right-10 z-50 bg-[#303031] text-white px-5 py-3.5 rounded-xl shadow-xl flex items-center gap-3 animate-slide-up max-w-sm\">\n          <Sparkles className=\"h-5 w-5 text-[#ffdbd0] shrink-0\" />\n          <p className=\"text-sm font-semibold\">{toastMessage}</p>\n        </div>\n      )}\n\n      {/* HERO OFFER BANNER */}\n      <section className=\"relative h-[280px] md:h-[400px] w-full rounded-2xl overflow-hidden shadow-lg group\">\n        <img \n          alt=\"Luxury Pizza table spread\" \n          className=\"w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-700\" \n          referrerPolicy=\"no-referrer\"\n          src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuD55EC6JU2Ccf8bZ_lQOIPcFj3kSuFakZ7Wxt-W0OpE6gHvNfyT49MPBvMPCJY1c2BABZdhUorBcsCBsRdjIi1hV8MN-qBhNvVfkFOGkwJwTBRXvQ5-xFFM-_YeWvKSO-ulKag_cSMFrCnyQzpDYMhwhkWuDXcHjGmocSq_VjOGID-zDA7slW4ITIXHdCFsr9Wqgp-iceaeLkg2slVfKC4jUW5I10I1LweWGGOkKZfWvhPdb4otIKn2F-2Gq6JwTISCzYme5748y0M\" \n        />\n        <div className=\"absolute inset-0 bg-gradient-to-r from-black/85 via-black/50 to-transparent flex flex-col justify-center px-8 md:px-16 text-white pb-4\">\n          <span className=\"bg-[#a83300] text-white px-4 py-1.5 rounded-full text-xs font-bold w-fit mb-4 select-none tracking-wider shadow-sm\">\n            LIMITED TIME ONLY\n          </span>\n          <h1 className=\"text-3xl md:text-5xl font-extrabold max-w-md md:max-w-xl mb-3 md:mb-5 leading-[1.1] tracking-tight\">\n            Get 50% Off Your First 3 Orders\n          </h1>\n          <p className=\"text-sm md:text-lg max-w-sm md:max-w-md opacity-90 mb-6 md:mb-8 font-normal leading-relaxed text-gray-100\">\n            Experience the best local restaurants delivered straight to your doorstep with zero delivery fees this weekend.\n          </p>\n          <button \n            onClick={handleClaimOffer}\n            disabled={claimedOffer}\n            className={`w-fit px-8 py-3.5 rounded-xl text-sm font-bold shadow-md transition-all active:scale-95 duration-200 ${claimedOffer ? \'bg-[#00c853] text-white\' : \'bg-white text-[#1b1c1c] hover:bg-[#ffdbd0] hover:text-[#a83300]\'}`}\n          >\n            {claimedOffer ? \'\342\234\223 Offer Claimed\' : \'Claim Offer Now\'}\n          </button>\n        </div>\n      </section>\n\n      {/* WHAT\'S ON YOUR MIND? CATEGORIES */}\n      <section className=\"relative\">\n        <div className=\"flex justify-between items-end mb-6\">\n          <div>\n            <h2 className=\"text-2xl font-bold text-[#1b1c1c] tracking-tight\">What\'s on your mind?</h2>\n            <p className=\"text-xs text-gray-500 mt-1\">Explore curated dishes and cuisines</p>\n          </div>\n          <div className=\"flex gap-2\">\n            <button \n              onClick={() => handleScroll(\'left\')}\n              className=\"p-2.5 rounded-full border border-gray-200 hover:bg-[#f5f3f3] transition-colors shadow-xs active:scale-90\"\n            >\n              <ChevronLeft className=\"h-5 w-5 text-gray-600\" />\n            </button>\n            <button \n              onClick={() => handleScroll(\'right\')}\n              className=\"p-2.5 rounded-full border border-gray-200 hover:bg-[#f5f3f3] transition-colors shadow-xs active:scale-90\"\n            >\n              <ChevronRight className=\"h-5 w-5 text-gray-600\" />\n            </button>\n          </div>\n        </div>\n\n        {/* Categories list */}\n        <div \n          ref={scrollContainerRef}\n          className=\"flex gap-8 overflow-x-auto scrollbar-none pb-4 snap-x -mx-4 px-4 scroll-smooth\"\n          style={{ scrollbarWidth: \'none\', msOverflowStyle: \'none\' }}\n        >\n          {/* \"All\" Category Badge */}\n          <div \n            onClick={() => setSelectedCategory(null)}\n            className=\"flex-shrink-0 flex flex-col items-center gap-3 cursor-pointer select-none snap-start\"\n          >\n            <div className={`w-20 h-20 md:w-28 md:h-28 rounded-full overflow-hidden border-2 flex items-center justify-center transition-all shadow-sm ${!selectedCategory ? \'border-[#a83300] bg-[#ffdbd0]\' : \'border-gray-100 bg-white hover:border-[#a83300]\'}`}>\n              <Sparkles className={`h-8 w-8 ${!selectedCategory ? \'text-[#a83300]\' : \'text-gray-400\'}`} />\n            </div>\n            <span className={`text-xs md:text-sm font-semibold font-sans tracking-tight transition-colors ${!selectedCategory ? \'text-[#a83300]\' : \'text-[#5f5e5e]\'}`}>All Cuisines</span>\n          </div>\n\n          {CATEGORIES.map((cat) => (\n            <div \n              key={cat.name}\n              onClick={() => setSelectedCategory(selectedCategory === cat.name ? null : cat.name)}\n              className=\"flex-shrink-0 flex flex-col items-center gap-3 cursor-pointer select-none snap-start group\"\n            >\n              <div className={`w-20 h-20 md:w-28 md:h-28 rounded-full overflow-hidden border-2 p-1.5 transition-all shadow-sm ${selectedCategory === cat.name ? \'border-[#a83300] bg-[#ffdbd0]\' : \'border-gray-100 bg-white group-hover:border-[#a83300]\'}`}>\n                <img \n                  src={cat.image} \n                  alt={cat.name} \n                  className=\"w-full h-full object-cover rounded-full\"\n                  referrerPolicy=\"no-referrer\" \n                />\n              </div>\n              <span className={`text-xs md:text-sm font-semibold font-sans tracking-tight transition-colors ${selectedCategory === cat.name ? \'text-[#a83300]\' : \'text-[#5f5e5e]\'}`}>\n                {cat.name}\n              </span>\n            </div>\n          ))}\n        </div>\n      </section>\n\n      {/* RECENTLY ORDERED SECTION */}\n      <section className=\"bg-[#f5f3f3]/50 rounded-2xl p-6 border border-gray-100\">\n        <h2 className=\"text-xl font-bold text-[#1b1c1c] tracking-tight mb-5 flex items-center gap-2\">\n          Recently Ordered\n        </h2>\n        <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n          {RECENTS.map((rec) => (\n            <div \n              key={rec.dishName}\n              className=\"bg-white rounded-2xl overflow-hidden hover:shadow-md transition-shadow group flex flex-col border border-gray-200/50\"\n            >\n              <div className=\"h-32 w-full overflow-hidden relative\">\n                <img \n                  src={rec.image} \n                  alt={rec.dishName} \n                  className=\"w-full h-full object-cover group-hover:scale-105 duration-500\" \n                  referrerPolicy=\"no-referrer\"\n                />\n                <span className=\"absolute bottom-2.5 left-2.5 text-[10px] uppercase tracking-wider font-bold bg-[#303031] text-white px-2 py-0.5 rounded-md\">\n                  Ordered 10 Oct\n                </span>\n              </div>\n              <div className=\"p-4 flex-1 flex flex-col justify-between gap-3\">\n                <div>\n                  <h3 className=\"font-bold text-sm text-[#1b1c1c] truncate\">{rec.restaurantName}</h3>\n                  <p className=\"text-xs text-gray-500 mt-1 truncate\">{rec.dishName}</p>\n                </div>\n                <div className=\"flex justify-between items-center mt-2.5\">\n                  <span className=\"text-[#a83300] font-extrabold text-sm\">${rec.price.toFixed(2)}</span>\n                  <button \n                    onClick={() => handleReorder(rec)}\n                    className=\"text-[#a83300] bg-[#ffdbd0] text-xs font-bold border border-[#outline-variant] px-4 py-1.5 rounded-full hover:bg-[#a83300] hover:text-white transition-all active:scale-95\"\n                  >\n                    Reorder\n                  </button>\n                </div>\n              </div>\n            </div>\n          ))}\n        </div>\n      </section>\n\n      {/* RESTAURANTS VIEW SECTION */}\n      <section id=\"restaurants-section\" className=\"scroll-mt-24\">\n        {/* Title and filters bar */}\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8\">\n          <div>\n            <h2 className=\"text-2xl font-bold text-[#1b1c1c] tracking-tight\">\n              {selectedCategory ? `${selectedCategory} Restaurants` : \'Top Rated Restaurants\'}\n            </h2>\n            <p className=\"text-xs text-gray-400 mt-1\">\n              Showing {processedRestaurants.length} premium kitchens near Downtown Manhattan\n            </p>\n          </div>\n\n          {/* Interactive filter caps */}\n          <div className=\"flex gap-3 relative flex-wrap md:flex-nowrap\">\n            {/* Free Shipping toggle */}\n            <button \n              onClick={() => setFilterFreeDelivery(!filterFreeDelivery)}\n              className={`flex items-center gap-1.5 px-4 py-2 border rounded-full text-xs font-semibold active:scale-95 transition-all ${filterFreeDelivery ? \'bg-[#ffdbd0] text-[#a83300] border-[#a83300]\' : \'border-gray-200 hover:bg-[#f5f3f3]\'}`}\n            >\n              Free Delivery\n            </button>\n\n            {/* General Filter popup trigger */}\n            <button \n              onClick={() => setShowFiltersDropdown(!showFiltersDropdown)}\n              className={`flex items-center gap-2 px-4 py-2 border rounded-full text-xs font-semibold active:scale-95 transition-all ${sortBy !== \'none\' ? \'bg-[#ffdbd0] text-[#a83300] border-[#a83300]\' : \'border-gray-200 hover:bg-[#f5f3f3]\'}`}\n            >\n              <SlidersHorizontal className=\"h-3.5 w-3.5\" />\n              <span>Sort & Filter: {sortBy === \'none\' ? \'Default\' : sortBy}</span>\n            </button>\n\n            {/* Dropdown element */}\n            {showFiltersDropdown && (\n              <div className=\"absolute right-0 top-11 z-50 bg-white rounded-xl shadow-xl p-4 border border-gray-100 flex flex-col gap-3 min-w-[200px] animate-slide-up\">\n                <div className=\"text-[10px] text-gray-400 font-bold uppercase tracking-wider border-b border-gray-100 pb-1.5\">\n                  Sort options\n                </div>\n                {[\n                  { id: \'none\', label: \'Default Order\' },\n                  { id: \'rating\', label: \'Recommended \342\255\220\' },\n                  { id: \'time\', label: \'Delivery Speed \342\232\241\' },\n                  { id: \'distance\', label: \'Nearby Distance \360\237\223\215\' }\n                ].map((opt) => (\n                  <button \n                    key={opt.id}\n                    onClick={() => { setSortBy(opt.id as any); setShowFiltersDropdown(false); }}\n                    className={`text-left text-xs py-2 px-2.5 rounded-lg font-medium transition-colors ${sortBy === opt.id ? \'bg-[#ffdbd0] text-[#a83300]\' : \'hover:bg-gray-50 text-gray-700\'}`}\n                  >\n                    {opt.label}\n                  </button>\n                ))}\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Main Grid */}\n        {processedRestaurants.length === 0 ? (\n          <div className=\"bg-[#f5f3f3] rounded-2xl p-12 text-center flex flex-col items-center justify-center gap-4\">\n            <AlertCircle className=\"h-10 w-10 text-gray-400\" />\n            <div>\n              <p className=\"font-bold text-base\">No restaurants match your search</p>\n              <p className=\"text-xs text-gray-500 mt-1\">Try resetting the filters or searching for something else</p>\n            </div>\n            <button \n              onClick={() => { setSortBy(\'none\'); setFilterFreeDelivery(false); setSelectedCategory(null); }}\n              className=\"text-xs font-bold text-white bg-[#a83300] px-5 py-2 rounded-xl mt-2\"\n            >\n              Reset All Filters\n            </button>\n          </div>\n        ) : (\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10\">\n            {processedRestaurants.map((res) => (\n              <div \n                key={res.id}\n                onClick={() => selectRestaurant(res)}\n                className=\"group cursor-pointer flex flex-col bg-white rounded-2xl overflow-hidden hover:shadow-md transition-all duration-300 border border-gray-100/84\"\n              >\n                {/* Visual Thumbnail */}\n                <div className=\"relative h-56 md:h-64 overflow-hidden shadow-sm\">\n                  <img \n                    src={res.image} \n                    alt={res.name} \n                    className=\"w-full h-full object-cover group-hover:scale-105 duration-700\" \n                    referrerPolicy=\"no-referrer\"\n                  />\n                  {/* Rating Tag */}\n                  <div className=\"absolute top-4 right-4 bg-white/95 backdrop-blur-xs px-2.5 py-1 rounded-lg flex items-center gap-1 shadow-sm border border-gray-100\">\n                    <Star className=\"h-4 w-4 text-amber-500 fill-amber-500\" />\n                    <span className=\"text-xs font-extrabold text-[#1b1c1c]\">{res.rating.toFixed(1)}</span>\n                  </div>\n                  {/* Discount or Free delivery tags */}\n                  <div className=\"absolute bottom-4 left-4 flex gap-2\">\n                    {res.isFreeDelivery && (\n                      <span className=\"bg-[#ffdbd0] text-[#a83300] font-sans font-bold px-3 py-1 rounded-full text-[10px] tracking-wide shadow-sm border border-[#e5beb2]\">\n                        Free Delivery\n                      </span>\n                    )}\n                    {res.discount && (\n                      <span className=\"bg-[#a83300] text-white font-sans font-bold px-3 py-1 rounded-full text-[10px] tracking-wide shadow-sm-dark\">\n                        {res.discount}\n                      </span>\n                    )}\n                  </div>\n                </div>\n\n                {/* Listing descriptors */}\n                <div className=\"p-4 flex flex-col justify-between flex-1 gap-2.5\">\n                  <div className=\"flex justify-between items-start gap-2\">\n                    <h4 className=\"text-base font-bold text-[#1b1c1c] tracking-tight truncate line-clamp-1 group-hover:text-[#a83300] transition-colors\">\n                      {res.name}\n                    </h4>\n                    <div className=\"text-right shrink-0\">\n                      <span className=\"text-xs font-bold text-[#1b1c1c] block\">{res.deliveryTime}</span>\n                      <span className=\"text-[10px] text-gray-400 font-medium block mt-0.5\">{res.distance} miles away</span>\n                    </div>\n                  </div>\n                  <p className=\"text-xs text-gray-500 font-medium truncate\">\n                    {res.tags.join(\' \342\200\242 \')}\n                  </p>\n                </div>\n              </div>\n            ))}\n          </div>\n        )}\n      </section>\n\n      {/* RESTAURANT DETAILED MENU DRAWER / MODAL */}\n      {menuModalOpen && selectedRestaurant && (\n        <div className=\"fixed inset-0 z-55 flex items-center justify-center p-4\">\n          {/* Backdrop overlay */}\n          <div \n            onClick={() => setMenuModalOpen(false)}\n            className=\"fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity\"\n          />\n\n          {/* Dialog Container */}\n          <div className=\"relative bg-white w-full max-w-2xl rounded-2xl overflow-hidden shadow-2xl flex flex-col max-h-[85vh] animate-scale-up font-sans\">\n            {/* Banner block */}\n            <div className=\"relative h-44 md:h-52 shrink-0\">\n              <img \n                src={selectedRestaurant.image} \n                alt={selectedRestaurant.name} \n                className=\"w-full h-full object-cover\" \n                referrerPolicy=\"no-referrer\"\n              />\n              <div className=\"absolute inset-0 bg-gradient-to-t from-black/85 via-black/40 to-transparent flex flex-col justify-end p-6 text-white\">\n                <span className=\"bg-[#ffdbd0] text-[#a83300] px-2 py-0.5 rounded text-[10px] font-bold uppercase w-fit mb-2\">\n                  Zyrop Partner Kitchen\n                </span>\n                <h3 className=\"text-xl md:text-2xl font-extrabold tracking-tight\">{selectedRestaurant.name}</h3>\n                <div className=\"flex items-center gap-4 text-xs mt-1.5 opacity-90\">\n                  <span className=\"flex items-center gap-1 text-amber-400 font-bold\">\n                    <Star className=\"h-4 w-4 fill-amber-400\" />\n                    {selectedRestaurant.rating.toFixed(1)}\n                  </span>\n                  <span>\342\200\242</span>\n                  <span>{selectedRestaurant.deliveryTime}</span>\n                  <span>\342\200\242</span>\n                  <span>{selectedRestaurant.distance} miles away</span>\n                </div>\n              </div>\n\n              {/* Close Button */}\n              <button \n                onClick={() => setMenuModalOpen(false)}\n                className=\"absolute top-4 right-4 bg-black/50 hover:bg-black/80 text-white p-1.5 rounded-full shadow-md transition-colors\"\n              >\n                <X className=\"h-5 w-5\" />\n              </button>\n            </div>\n\n            {/* Menu contents list */}\n            <div className=\"p-6 overflow-y-auto flex-1 flex flex-col gap-6\">\n              <div className=\"flex justify-between items-center border-b border-gray-100 pb-3\">\n                <h4 className=\"font-bold text-[#1b1c1c] text-sm uppercase tracking-wider\">Presenting Menu</h4>\n                <p className=\"text-xs text-gray-400 font-medium\">Select item to add to Cart</p>\n              </div>\n\n              {/* Loop dishes */}\n              <div className=\"space-y-4\">\n                {selectedRestaurant.menu.map((item) => (\n                  <div \n                    key={item.id}\n                    className=\"p-4 bg-[#f5f3f3]/40 border border-gray-100 rounded-xl hover:border-[#e5beb2] transition-colors flex flex-col sm:flex-row gap-4 justify-between\"\n                  >\n                    <div className=\"flex-1\">\n                      <h5 className=\"font-bold text-sm text-[#1b1c1c]\">{item.name}</h5>\n                      <p className=\"text-xs text-gray-500 mt-1 lines text-left leading-relaxed\">\n                        {item.description}\n                      </p>\n                      \n                      {/* Customization Options as Chips if present */}\n                      {item.customizationOptions && item.customizationOptions.length > 0 && (\n                        <div className=\"mt-3.5 flex flex-wrap gap-1.5 items-center\">\n                          <span className=\"text-[9px] text-[#5c4037] font-bold uppercase tracking-wide mr-1\">\n                            Customize:\n                          </span>\n                          {item.customizationOptions.map((opt) => (\n                            <button \n                              key={opt}\n                              onClick={() => {\n                                // Toggle active customization\n                                setActiveCustomization(activeCustomization === opt ? \'\' : opt);\n                              }}\n                              className={`px-2 py-0.5 rounded text-[10px] font-semibold border transition-all ${activeCustomization === opt ? \'bg-[#ffdbd0] text-[#a83300] border-[#a83300]\' : \'bg-white text-gray-500 border-gray-200\'}`}\n                            >\n                              {opt}\n                            </button>\n                          ))}\n                        </div>\n                      )}\n                    </div>\n\n                    <div className=\"flex sm:flex-col justify-between items-end gap-3 shrink-0\">\n                      <span className=\"text-[#a83300] font-extrabold text-sm\">${item.price.toFixed(2)}</span>\n                      <button \n                        onClick={() => {\n                          onAddToCart(item, selectedRestaurant, activeCustomization || undefined);\n                          displayToast(`\360\237\233\222 Added ${item.name} to your Cart!`);\n                          // Reset customization\n                          setActiveCustomization(\'\');\n                        }}\n                        className=\"bg-[#a83300] hover:bg-[#d24200] text-white h-8 w-28 text-xs font-bold rounded-lg flex items-center justify-center gap-1.5 self-end transition-all active:scale-95 shadow-xs\"\n                      >\n                        <Plus className=\"h-3.5 w-3.5\" />\n                        <span>Add to Cart</span>\n                      </button>\n                    </div>\n                  </div>\n                ))}\n              </div>\n            </div>\n\n            {/* Bottom info link */}\n            <div className=\"bg-[#f5f3f3] py-4 px-6 shrink-0 flex justify-between items-center border-t border-gray-100\">\n              <span className=\"text-xs text-secondary-container-on font-semibold flex items-center gap-1 text-[#5c4037]\">\n                <Clock className=\"h-4 w-4\" />\n                Sizzling hot delivery guaranteed\n              </span>\n              <button \n                onClick={() => { setMenuModalOpen(false); onScreenChange(\'cart\'); }}\n                className=\"text-xs font-bold text-[#a83300] flex items-center gap-1.5\"\n              >\n                <span>View My Cart</span>\n                <ChevronRight className=\"h-4 w-4\" />\n              </button>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
    diff {
      unified_diff {
        lines {
          text: "/**"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
