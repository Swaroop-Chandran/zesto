  file_change {
    absolute_path_uri: "file:///src/components/OrderTracking.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect } from \'react\';\nimport { \n  ArrowLeft, \n  Headphones, \n  Home as HomeIcon, \n  MapPin, \n  Navigation, \n  Check, \n  Loader2, \n  MessageSquare, \n  Phone, \n  Star, \n  Utensils, \n  Play, \n  RotateCcw, \n  Send \n} from \'lucide-react\';\nimport { ActiveOrder, TrackingStep } from \'../types\';\n\ninterface OrderTrackingProps {\n  activeOrder: ActiveOrder | null;\n  onScreenChange: (screen: \'home\' | \'cart\' | \'tracking\') => void;\n}\n\nexport default function OrderTracking({\n  activeOrder,\n  onScreenChange\n}: OrderTrackingProps) {\n  // Setup standard state for simulating tracking progress\n  const [simulationRunning, setSimulationRunning] = useState(false);\n  const [simStep, setSimStep] = useState(2); // Start at \"Out for delivery\" (index 2)\n  const [agentMinutesAway, setAgentMinutesAway] = useState(8);\n  const [agentPosition, setAgentPosition] = useState({ top: \'48%\', left: \'46%\' });\n  \n  // Chat Overlay state\n  const [chatOpen, setChatOpen] = useState(false);\n  const [chatMessages, setChatMessages] = useState([\n    { sender: \'driver\', text: \'Hi! I have just picked up your fresh hot order. Heading towards you now!\', time: \'12:20 PM\' }\n  ]);\n  const [newMessage, setNewMessage] = useState(\'\');\n\n  // Call status state\n  const [callingState, setCallingState] = useState<\'idle\' | \'calling\' | \'connected\'>(\'idle\');\n\n  // If no active order exists (meaning user visited without placing one), supply a default mock order so they can experiment!\n  const order = activeOrder || {\n    id: \'#ZY-8821\',\n    restaurantName: \'The Steakhouse Grill\',\n    items: [\n      { name: \'Double Truffle Burger\', quantity: 2, price: 24.00 }\n    ],\n    subtotal: 24.00,\n    deliveryFee: 2.99,\n    taxes: 1.45,\n    total: 28.44,\n    estArrival: \'12:45 PM\',\n    agent: {\n      name: \'Marcus Rodriguez\',\n      rating: \'4.9\',\n      deliveries: \'2k+ deliveries\',\n      image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuB8N79NnzBkNjJlH_j1MDJj1is3ZLHe5zf4QNLtwbxOQq9elB6w1-Eq8iK8QPl_kecxA_EkIvhpm8OgWEd4ajqCgMGzg6E-hsv5yjY-_3geRtReum09madJb2FykVO-iBptXyO0aAo7QKeUi_6V3VGDQHR_-IvGjgdbC6S_F7Nn3-nU5Cndtj6Oa_nD4-OhDUQvWly8lPVokasK_Cutr4tewAcOGRELa8H2W5TiFlz-XitgBe7vNL4pPys9N4ZRNJm_xGddPR209i4\',\n      phone: \'+1 (555) 902-1822\'\n    },\n    steps: [\n      { title: \'Order Placed\', time: \'12:10 PM\', description: \'Order was acknowledged\', status: \'completed\' },\n      { title: \'Preparing your meal\', time: \'12:15 PM\', description: \'Fresh culinary work in kitchen\', status: \'completed\' },\n      { title: \'Out for Delivery\', time: \'12:25 PM\', description: \'Your agent is 2.4km away\', status: \'active\' },\n      { title: \'Order Delivered\', time: \'12:45 PM\', description: \'Expected at door\', status: \'upcoming\' }\n    ] as TrackingStep[],\n    currentStepIndex: 2\n  };\n\n  // Run simulation timeline tick if enabled\n  useEffect(() => {\n    let timer: any;\n    if (simulationRunning) {\n      timer = setInterval(() => {\n        if (simStep === 2) {\n          // Progress within driving phase\n          if (agentMinutesAway > 2) {\n            setAgentMinutesAway(prev => prev - 2);\n            // Move agent closer to Home (Home location: top: 25%, left: 25%)\n            setAgentPosition({\n              top: `${48 - (8 - agentMinutesAway) * 2}%`,\n              left: `${46 - (8 - agentMinutesAway) * 2}%`\n            });\n            // Append incoming message\n            setChatMessages(prev => [\n              ...prev,\n              { sender: \'driver\', text: `Traffic is light! I am now just ${agentMinutesAway - 2} minutes away close to Skyline Towers. See you soon!`, time: \'12:35 PM\' }\n            ]);\n          } else {\n            // Arrived at door, advance step\n            setSimStep(3);\n            setAgentMinutesAway(0);\n            setAgentPosition({ top: \'25%\', left: \'25%\' });\n            setChatMessages(prev => [\n              ...prev,\n              { sender: \'driver\', text: \"I have arrived at Skyline Towers entrance. Walking up to Apt 4B with your warm food!\", time: \'12:44 PM\' }\n            ]);\n          }\n        } else if (simStep === 3) {\n          // Delivered\n          setSimulationRunning(false);\n          setChatMessages(prev => [\n            ...prev,\n            { sender: \'driver\', text: \"Deliver accomplished! Perfect safe drop. Enjoy the hot meals! \342\255\220 Please rate five stars!\", time: \'12:45 PM\' }\n          ]);\n        }\n      }, 4000);\n    }\n    return () => clearInterval(timer);\n  }, [simulationRunning, simStep, agentMinutesAway]);\n\n  const toggleSimulation = () => {\n    if (simStep === 3) {\n      // Reset\n      setSimStep(2);\n      setAgentMinutesAway(8);\n      setAgentPosition({ top: \'48%\', left: \'46%\' });\n      setChatMessages([\n        { sender: \'driver\', text: \'Hi! I have just picked up your fresh hot order. Heading towards you now!\', time: \'12:20 PM\' }\n      ]);\n    }\n    setSimulationRunning(!simulationRunning);\n  };\n\n  const handleSendMessage = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newMessage.trim()) return;\n    \n    const userMsg = { sender: \'customer\', text: newMessage, time: \'Just now\' };\n    setChatMessages(prev => [...prev, userMsg]);\n    setNewMessage(\'\');\n\n    // Quick responder mock\n    setTimeout(() => {\n      setChatMessages(prev => [\n        ...prev,\n        { sender: \'driver\', text: \'Received that! Thanks for the tip, will follow instructions.\', time: \'Just now\' }\n      ]);\n    }, 1500);\n  };\n\n  const triggerCallSim = () => {\n    setCallingState(\'calling\');\n    setTimeout(() => {\n      setCallingState(\'connected\');\n    }, 2000);\n  };\n\n  const hangUpCall = () => {\n    setCallingState(\'idle\');\n  };\n\n  return (\n    <div className=\"max-w-[1280px] mx-auto px-4 md:px-10 py-6 md:py-10 grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 font-sans text-[#1b1c1c]\">\n      \n      {/* Simulation Banner header */}\n      <div className=\"col-span-12 bg-[#ffdbd0]/50 border border-[#e5beb2] rounded-2xl p-4 flex flex-col sm:flex-row justify-between items-center gap-4\">\n        <div className=\"flex items-center gap-3\">\n          <span className=\"relative flex h-3 w-3 shrink-0\">\n            <span className=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75\"></span>\n            <span className=\"relative inline-flex rounded-full h-3 w-3 bg-[#a83300]\"></span>\n          </span>\n          <div>\n            <p className=\"text-xs font-bold text-[#a83300] uppercase tracking-wider\">Proto simulation engine</p>\n            <p className=\"text-xs text-gray-600 mt-0.5\">Test real-world logistics updates with active time-lapse</p>\n          </div>\n        </div>\n        <div className=\"flex gap-2\">\n          <button \n            onClick={toggleSimulation}\n            className=\"bg-[#a83300] hover:bg-[#d24200] text-white px-4 py-2 rounded-lg text-xs font-bold flex items-center gap-2 shadow-xs\"\n          >\n            {simulationRunning ? (\n              <>\n                <Loader2 className=\"h-3.5 w-3.5 animate-spin\" />\n                <span>Sim Running...</span>\n              </>\n            ) : (\n              <>\n                <Play className=\"h-3.5 w-3.5\" />\n                <span>{simStep === 3 ? \'Restart Simulation\' : \'Run Simulation\'}</span>\n              </>\n            )}\n          </button>\n          <button \n            onClick={() => {\n              setSimStep(2);\n              setAgentMinutesAway(8);\n              setAgentPosition({ top: \'48%\', left: \'46%\' });\n              setSimulationRunning(false);\n              setChatMessages([\n                { sender: \'driver\', text: \'Hi! I have just picked up your fresh hot order. Heading towards you now!\', time: \'12:20 PM\' }\n              ]);\n            }}\n            className=\"bg-white border border-gray-200 text-[#1b1c1c] px-3\' py-2 rounded-lg text-xs font-bold hover:bg-gray-50 flex items-center justify-center p-2\"\n            title=\"Reset simulation details\"\n          >\n            <RotateCcw className=\"h-3.5 w-3.5\" />\n          </button>\n        </div>\n      </div>\n\n      {/* Main Back header */}\n      <div className=\"col-span-12 flex justify-between items-center\">\n        <div className=\"flex items-center gap-4\">\n          <button \n            onClick={() => onScreenChange(\'home\')}\n            className=\"p-2.5 rounded-full border border-gray-200 hover:bg-[#f5f3f3] transition-colors active:scale-90\"\n          >\n            <ArrowLeft className=\"h-5 w-5 text-[#a83300]\" />\n          </button>\n          <div>\n            <div className=\"text-[10px] text-gray-400 font-bold uppercase tracking-wider\">Delivery Tracker</div>\n            <h1 className=\"text-xl md:text-2xl font-extrabold text-[#a83300] tracking-tight flex items-center gap-2\">\n              Order {order.id}\n            </h1>\n          </div>\n        </div>\n\n        <button \n          onClick={() => alert(\"Connecting with Zyrop Support team...\")}\n          className=\"hover:bg-[#ffdbd0] p-2.5 rounded-full text-[#a83300] border border-gray-100 transition-colors\"\n          title=\"Connect Support Agent\"\n        >\n          <Headphones className=\"h-5 w-5\" />\n        </button>\n      </div>\n\n      {/* LEFT COLUMN: Map & Driver Messaging */}\n      <div className=\"lg:col-span-7 flex flex-col gap-6\">\n        \n        {/* INTERACTIVE TRACKING MAP PANEL */}\n        <div className=\"relative rounded-2xl overflow-hidden border border-gray-200 h-[380px] bg-[#f5f3f3] shadow-md group\">\n          <img \n            src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuD1V3Mwcf8elc7rZfVYmG1TSPjt2mMmwlNKVX3matjNgYAQZH3zBHB5vY_E8NhEZxDdR7mzwnYTemwa-w0xtV5lqc5hn3PBJMw6GZPxlLE-SREzFwjJFdkxOVkPWg2hMAlPIcLBKsQ1iMFVp8ArK060U_Dby1SIx3o7qfBiXDpLyOMnP1MV5o2vgyOW40P8YDQWU81QgFwNmixN74U6yqwwH8PHeLT5bci4_4wUd9jO3CmFveYKXNJaoAxcfV2A8WI4TI2FvI-0rvk\" \n            alt=\"Live Logistics tracking map\" \n            className=\"w-full h-full object-cover opacity-60 grayscale brightness-105\"\n            referrerPolicy=\"no-referrer\"\n          />\n          <div className=\"absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-white via-white/40 to-transparent pointer-events-none\"></div>\n\n          {/* CUSTOMER HOME LOCATOR (Home location: top: 25%, left: 25%) */}\n          <div className=\"absolute top-[25%] left-[25%] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center z-10\">\n            <div className=\"bg-[#303031] text-white rounded-full p-2.5 shadow-md border-2 border-white\">\n              <HomeIcon className=\"h-4.5 w-4.5 fill-white\" />\n            </div>\n            <div className=\"bg-white border border-gray-200 px-2.5 py-1 rounded-md shadow-sm mt-1.5 shrink-0 max-w-[124px]\">\n              <p className=\"text-[10px] font-extrabold text-center text-gray-800\">Home Dropoff</p>\n            </div>\n          </div>\n\n          {/* RESTAURANT LOCATOR (Restaurant location: bottom: 33%, right: 24% => top 67%, left 76%) */}\n          <div className=\"absolute top-[67%] left-[76%] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center z-10\">\n            <div className=\"bg-[#a83300] text-white rounded-full p-2.5 shadow-md border-2 border-white\">\n              <Utensils className=\"h-4.5 w-4.5 fill-white\" />\n            </div>\n            <div className=\"bg-white border border-gray-200 px-2.5 py-1 rounded-md shadow-sm mt-1.5 shrink-0 max-w-[124px]\">\n              <p className=\"text-[10px] font-extrabold text-center text-gray-800 text-[#a83300] truncate\">\n                {order.restaurantName}\n              </p>\n            </div>\n          </div>\n\n          {/* DELIVERY AGENT RIDER LOCATOR (Dynamic location based on state) */}\n          <div \n            className=\"absolute transition-all duration-1000 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center z-20\"\n            style={{ top: agentPosition.top, left: agentPosition.left }}\n          >\n            {simStep === 3 ? (\n              <div className=\"bg-[#00c853] text-white rounded-full p-3 shadow-xl border-2 border-white scale-110\">\n                <Check className=\"h-5 w-5 text-white\" />\n              </div>\n            ) : (\n              <div className=\"bg-[#00c853] text-white rounded-full p-3 shadow-xl border-2 border-white scale-110 animate-bounce\">\n                <Navigation className=\"h-5 w-5 text-white fill-white rotate-45\" />\n              </div>\n            )}\n            \n            <div className=\"bg-[#00c853] text-white text-[10px] font-bold px-3 py-1 rounded-full shadow-md mt-2 shrink-0 flex items-center gap-1.5\">\n              <span className=\"w-1.5 h-1.5 bg-white rounded-full animate-ping\"></span>\n              <span>{simStep === 3 ? \'Arrived!\' : `${agentMinutesAway} mins away`}</span>\n            </div>\n          </div>\n        </div>\n\n        {/* MESSAGING OVERLAY OR SECTION */}\n        <section className=\"bg-white rounded-2xl border border-gray-200 p-5 shadow-xs flex flex-col gap-4\">\n          <div className=\"flex justify-between items-center border-b border-gray-50 pb-3\">\n            <div className=\"flex items-center gap-2\">\n              <MessageSquare className=\"h-4 w-4 text-[#a83300]\" />\n              <h3 className=\"font-bold text-sm text-[#1b1c1c]\">Secure Chat with {order.agent.name}</h3>\n            </div>\n            <span className=\"w-1.5 h-1.5 bg-[#00c853] rounded-full\" />\n          </div>\n\n          {/* Message threads mock */}\n          <div className=\"h-48 overflow-y-auto px-1 space-y-3.5 text-xs text-left\">\n            {chatMessages.map((msg, idx) => (\n              <div \n                key={idx}\n                className={`max-w-[85%] rounded-2xl p-3 text-sm leading-relaxed ${msg.sender === \'driver\' ? \'bg-[#f5f3f3]/60 mr-auto text-gray-800 rounded-tl-none\' : \'bg-[#ffdbd0]/60 ml-auto text-gray-800 rounded-tr-none\'}`}\n              >\n                <p className=\"font-sans leading-relaxed\">{msg.text}</p>\n                <span className=\"text-[9px] text-gray-400 font-bold text-right block mt-1 uppercase mt-0.5\">{msg.time}</span>\n              </div>\n            ))}\n          </div>\n\n          {/* Type form */}\n          <form onSubmit={handleSendMessage} className=\"flex gap-2 border-t border-gray-50 pt-3\">\n            <input \n              type=\"text\" \n              placeholder=\"Type message to Marcus...\"\n              className=\"bg-[#f5f3f3] focus:bg-white text-sm px-4 py-2.5 rounded-xl flex-1 outline-none focus:ring-1 focus:ring-[#a83300] border-none text-gray-800\"\n              value={newMessage}\n              onChange={(e) => setNewMessage(e.target.value)}\n            />\n            <button \n              type=\"submit\"\n              className=\"bg-[#a83300] text-white p-2.5 rounded-xl hover:bg-[#d24200] active:scale-95 transition-transform\"\n            >\n              <Send className=\"h-4 w-4\" />\n            </button>\n          </form>\n        </section>\n      </div>\n\n      {/* RIGHT COLUMN: Live timeline milestones & Driver details */}\n      <div className=\"lg:col-span-5 flex flex-col gap-8\">\n        \n        {/* DELIVERABLE METRICS & TIMES */}\n        <section className=\"bg-white rounded-2xl border border-gray-200 p-6 shadow-sm\">\n          <div className=\"flex justify-between items-start mb-6 border-b border-gray-55 pb-4\">\n            <div>\n              <p className=\"text-xs text-gray-500 font-medium\">Estimated Arrival</p>\n              <h2 className=\"text-2xl font-extrabold text-[#1b1c1c] tracking-tight mt-0.5\">\n                {simStep === 3 ? \'Delivered!\' : `12:45 PM`}\n              </h2>\n            </div>\n            <span className={`px-3 py-1 rounded-full text-xs font-extrabold ${simStep === 3 ? \'bg-[#00c853]/10 text-[#00c853]\' : \'bg-[#ffdbd0] text-[#a83300]\'}`}>\n              {simStep === 3 ? \'Delivered\' : \'On Track\'}\n            </span>\n          </div>\n\n          {/* TIMELINE STEP DETAILS */}\n          <div className=\"relative pl-8 space-y-6\">\n            \n            {/* Mile 1: Order Placed */}\n            <div className=\"relative\">\n              <div className=\"absolute -left-8 top-1.5 w-6 h-6 rounded-full bg-[#00c853] flex items-center justify-center text-white z-10 border-4 border-white ring-2 ring-transparent\">\n                <Check className=\"h-3 w-3 text-white stroke-[3px]\" />\n              </div>\n              <div className=\"absolute -left-5 top-7 bottom-0 w-[2px] bg-[#00c853] h-10\"></div>\n              <div>\n                <h4 className=\"font-bold text-sm text-[#1b1c1c]\">Order Placed</h4>\n                <p className=\"text-xs text-gray-500 mt-1\">12:10 PM \342\200\242 Payment Verified</p>\n              </div>\n            </div>\n\n            {/* Mile 2: Preparing */}\n            <div className=\"relative\">\n              <div className=\"absolute -left-8 top-1.5 w-6 h-6 rounded-full bg-[#00c853] flex items-center justify-center text-white z-10 border-4 border-white\">\n                <Check className=\"h-3 w-3 text-white stroke-[3px]\" />\n              </div>\n              <div className={`absolute -left-5 top-7 bottom-0 w-[2px] h-10 ${simStep >= 2 ? \'bg-[#00c853]\' : \'bg-gray-200\'}`}></div>\n              <div>\n                <h4 className=\"font-bold text-sm text-[#1b1c1c]\">Preparing your meal</h4>\n                <p className=\"text-xs text-gray-500 mt-1\">12:15 PM \342\200\242 Fresh culinary craft</p>\n              </div>\n            </div>\n\n            {/* Mile 3: Out for delivery */}\n            <div className=\"relative\">\n              <div className={`absolute -left-8 top-1.5 w-6 h-6 rounded-full flex items-center justify-center z-10 border-4 border-white ${simStep >= 2 ? \'bg-[#a83300]\' : \'bg-gray-200\'}`}>\n                {simStep > 2 ? (\n                  <Check className=\"h-3 w-3 text-white stroke-[3px]\" />\n                ) : (\n                  <div className=\"w-1.5 h-1.5 bg-white rounded-full animate-ping\"></div>\n                )}\n              </div>\n              <div className={`absolute -left-5 top-7 bottom-0 w-[2px] h-10 ${simStep >= 3 ? \'bg-[#00c853]\' : \'bg-gray-200\'}`}></div>\n              <div>\n                <h4 className={`font-bold text-sm ${simStep === 2 ? \'text-[#a83300]\' : \'text-gray-800\'}`}>\n                  Out for Delivery\n                </h4>\n                <p className=\"text-xs text-gray-500 mt-1\">\n                  {simStep === 2 ? `Delivery Agent is ${agentMinutesAway} mins away` : \'Agent delivered warm package\'}\n                </p>\n              </div>\n            </div>\n\n            {/* Mile 4: Delivered */}\n            <div className=\"relative\">\n              <div className={`absolute -left-8 top-1.5 w-6 h-6 rounded-full flex items-center justify-center z-10 border-4 border-white ${simStep === 3 ? \'bg-[#00c853]\' : \'bg-gray-200\'}`}>\n                <Check className=\"h-3 w-3 text-white stroke-[3px]\" />\n              </div>\n              <div>\n                <h4 className={`font-bold text-sm ${simStep === 3 ? \'text-[#00c853]\' : \'text-gray-400\'}`}>\n                  Order Delivered\n                </h4>\n                <p className=\"text-xs text-gray-400 mt-1\">Expected dropoff by 12:45 PM</p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        {/* DELIVERY AGENT CARD */}\n        <section className=\"bg-white rounded-2xl border border-gray-200 p-5 shadow-xs\">\n          <div className=\"flex gap-4 items-center\">\n            <img \n              src={order.agent.image} \n              alt={order.agent.name} \n              className=\"w-14 h-14 rounded-full object-cover border-2 border-[#ffdbd0] shrink-0\"\n              referrerPolicy=\"no-referrer\" \n            />\n            <div className=\"flex-1\">\n              <p className=\"text-[10px] text-gray-400 font-bold uppercase tracking-wider\">Assigned Agent</p>\n              <h4 className=\"font-bold text-sm text-[#1b1c1c]\">{order.agent.name}</h4>\n              <div className=\"flex items-center gap-1.5 mt-0.5\">\n                <Star className=\"h-3.5 w-3.5 text-[#a83300] fill-[#a83300]\" />\n                <span className=\"text-[11px] font-bold text-gray-800\">{order.agent.rating} ({order.agent.deliveries})</span>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-2 gap-3 mt-5\">\n            <button \n              onClick={() => { setChatOpen(true); alert(\"Chat established with Marcus below!\"); }}\n              className=\"px-4 py-3 rounded-xl border border-gray-200 bg-[#f5f3f3] text-gray-800 flex items-center justify-center gap-2 text-xs font-bold hover:bg-gray-100 active:scale-95 transition-transform\"\n            >\n              <MessageSquare className=\"h-4 w-4\" />\n              <span>Query Message</span>\n            </button>\n            <button \n              onClick={triggerCallSim}\n              className=\"px-4 py-3 rounded-xl bg-[#a83300] text-white flex items-center justify-center gap-2 text-xs font-bold hover:bg-[#d24200] active:scale-95 transition-transform shadow-xs\"\n            >\n              <Phone className=\"h-4 w-4\" />\n              <span>Call Marcus</span>\n            </button>\n          </div>\n        </section>\n\n        {/* ORDER SUMMARY (ITEMS SECURED OUTSIDE) */}\n        <section className=\"bg-white rounded-2xl border border-gray-200 p-5 shadow-xs\">\n          <h3 className=\"font-bold text-sm text-[#1b1c1c] uppercase tracking-wider mb-4\">Summary checklist</h3>\n          <div className=\"space-y-3\">\n            {order.items.map((item, id) => (\n              <div key={id} className=\"flex justify-between items-center text-sm font-sans font-medium text-gray-800\">\n                <div className=\"flex items-center gap-2.5\">\n                  <div className=\"w-2.5 h-2.5 bg-[#a83300]/20 rounded-full flex items-center justify-center shrink-0\">\n                    <div className=\"w-1.2 h-1.2 bg-[#a83300] rounded-full\"></div>\n                  </div>\n                  <span>{item.name} <span className=\"text-xs text-gray-400\">x{item.quantity}</span></span>\n                </div>\n                <span className=\"font-bold text-gray-800\">${(item.price * item.quantity).toFixed(2)}</span>\n              </div>\n            ))}\n            <div className=\"border-t border-gray-50 pt-2.5 flex justify-between text-xs text-gray-400\">\n              <span>Receipt subtotal:</span>\n              <span>${order.subtotal.toFixed(2)}</span>\n            </div>\n            <div className=\"flex justify-between text-xs font-bold text-[#a83300]\">\n              <span>Final Paid Amount:</span>\n              <span>${order.total.toFixed(2)}</span>\n            </div>\n          </div>\n        </section>\n      </div>\n\n      {/* CALLING STATUS OVERLAY SIMULATOR */}\n      {callingState !== \'idle\' && (\n        <div className=\"fixed inset-0 z-55 bg-black/84 flex items-center justify-center p-4 backdrop-blur-sm animate-fade-in font-sans\">\n          <div className=\"bg-[#303031] text-white w-full max-w-xs rounded-2xl p-6 text-center shadow-2xl border border-gray-800 flex flex-col items-center gap-6 animate-scale-up\">\n            <div className=\"relative\">\n              <img \n                src={order.agent.image} \n                alt={order.agent.name} \n                className=\"w-24 h-24 rounded-full object-cover border-4 border-[#a83300]\"\n                referrerPolicy=\"no-referrer\" \n              />\n              <div className=\"absolute -bottom-1 -right-1 bg-[#00c853] p-1.5 rounded-full border-2 border-white\">\n                <Phone className=\"h-4 w-4 text-white fill-white\" />\n              </div>\n            </div>\n\n            <div>\n              <h3 className=\"font-black text-lg text-white\">{order.agent.name}</h3>\n              <p className=\"text-xs text-gray-400 mt-1 uppercase tracking-widest font-bold\">\n                {callingState === \'calling\' ? \'Calling...\' : \'Connected (Secure Line)\'}\n              </p>\n            </div>\n\n            {callingState === \'calling\' ? (\n              <p className=\"text-xs text-gray-450 italic\">Placing cellular link...</p>\n            ) : (\n              <div className=\"flex flex-col gap-1.5 items-center\">\n                <p className=\"text-xs text-[#00c853] font-bold\">Connected speaking line active</p>\n                <p className=\"text-[10px] text-gray-500 font-bold\">00:12 min elapsed</p>\n              </div>\n            )}\n\n            <button \n              onClick={hangUpCall}\n              className=\"bg-red-500 hover:bg-red-600 text-white w-full py-3.5 rounded-xl font-bold text-sm tracking-wider shadow-md shadow-red-500/20 active:scale-95 transition-transform\"\n            >\n              HANG UP\n            </button>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
