      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React from \'react\';\nimport { Globe, Megaphone, Share2, Smartphone, Apple } from \'lucide-react\';\n\nexport default function Footer() {\n  return (\n    <footer className=\"bg-[#e4e2e2] dark:bg-[#303031] border-t border-[#e5beb2]/40 mt-16 md:mt-24 pb-20 md:pb-8\">\n      <div className=\"max-w-[1280px] mx-auto px-6 md:px-10 py-12 md:py-16 grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8\">\n        {/* Brand Column */}\n        <div className=\"flex flex-col gap-4\">\n          <span className=\"text-xl font-extrabold text-[#a83300]\">ZyropFoodOrder</span>\n          <p className=\"text-sm text-[#5c4037] dark:text-gray-350 max-w-xs leading-relaxed font-sans\">\n            Delivering your favorite meals from top-rated restaurants right to your doorstep, fresh and fast.\n          </p>\n          <div className=\"flex gap-4 mt-2\">\n            <button className=\"h-[36px] w-[36px] items-center justify-center flex bg-white/70 dark:bg-black/20 hover:bg-[#ffdbd0] text-[#5f5e5e] hover:text-[#a83300] rounded-full transition-colors shadow-sm cursor-pointer border border-transparent\">\n              <Globe className=\"h-[18px] w-[18px]\" />\n            </button>\n            <button className=\"h-[36px] w-[36px] items-center justify-center flex bg-white/70 dark:bg-black/20 hover:bg-[#ffdbd0] text-[#5f5e5e] hover:text-[#a83300] rounded-full transition-colors shadow-sm cursor-pointer border border-transparent\">\n              <Megaphone className=\"h-[18px] w-[18px]\" />\n            </button>\n            <button className=\"h-[36px] w-[36px] items-center justify-center flex bg-white/70 dark:bg-black/20 hover:bg-[#ffdbd0] text-[#5f5e5e] hover:text-[#a83300] rounded-full transition-colors shadow-sm cursor-pointer border border-transparent\">\n              <Share2 className=\"h-[18px] w-[18px]\" />\n            </button>\n          </div>\n        </div>\n\n        {/* Company Links */}\n        <div className=\"flex flex-col gap-3 font-sans\">\n          <h5 className=\"font-bold text-[#1b1c1c] text-sm tracking-wide\">Company</h5>\n          <nav className=\"flex flex-col gap-2.5 text-sm text-[#5c4037] dark:text-gray-300\">\n            <a href=\"#about\" className=\"hover:text-[#a83300] transition-colors\">About Us</a>\n            <a href=\"#partner-with-us\" className=\"hover:text-[#a83300] transition-colors\">Partner With Us</a>\n            <a href=\"#careers\" className=\"hover:text-[#a83300] transition-colors\">Careers</a>\n            <a href=\"#press\" className=\"hover:text-[#a83300] transition-colors\">Press</a>\n          </nav>\n        </div>\n\n        {/* Legal & Support Links */}\n        <div className=\"flex flex-col gap-3 font-sans\">\n          <h5 className=\"font-bold text-[#1b1c1c] text-sm tracking-wide\">Legal & Support</h5>\n          <nav className=\"flex flex-col gap-2.5 text-sm text-[#5c4037] dark:text-gray-300\">\n            <a href=\"#privacy\" className=\"hover:text-[#a83300] transition-colors\">Privacy Policy</a>\n            <a href=\"#terms\" className=\"hover:text-[#a83300] transition-colors\">Terms of Service</a>\n            <a href=\"#help\" className=\"hover:text-[#a83300] transition-colors\">Help Center</a>\n            <a href=\"#contact\" className=\"hover:text-[#a83300] transition-colors\">Contact</a>\n          </nav>\n        </div>\n\n        {/* Apps Download Column */}\n        <div className=\"flex flex-col gap-4 font-sans\">\n          <h5 className=\"font-bold text-[#1b1c1c] text-sm tracking-wide\">Get App</h5>\n          <p className=\"text-xs text-[#5c4037] dark:text-gray-300\">Available on iOS and Android</p>\n          <div className=\"flex flex-col gap-3 max-w-[180px]\">\n            <a \n              href=\"#app-store\" \n              className=\"bg-[#303031] hover:bg-black text-white rounded-xl px-4 py-2 flex items-center gap-3 transition-colors shadow-md border border-gray-800\"\n            >\n              <Apple className=\"h-6 w-6 text-white\" />\n              <div>\n                <p className=\"text-[9px] text-[#e5beb2] uppercase leading-none font-medium\">Download on</p>\n                <p className=\"font-bold text-xs leading-tight\">App Store</p>\n              </div>\n            </a>\n            <a \n              href=\"#google-play\" \n              className=\"bg-[#303031] hover:bg-black text-white rounded-xl px-4 py-2 flex items-center gap-3 transition-colors shadow-md border border-gray-800\"\n            >\n              <Smartphone className=\"h-6 w-6 text-white\" />\n              <div>\n                <p className=\"text-[9px] text-[#e5beb2] uppercase leading-none font-medium\">Get it on</p>\n                <p className=\"font-bold text-xs leading-tight\">Google Play</p>\n              </div>\n            </a>\n          </div>\n        </div>\n      </div>\n\n      <div className=\"border-t border-[#e5beb2]/20 py-6 px-10 max-w-[1280px] mx-auto flex justify-between items-center text-xs text-gray-500 font-sans\">\n        <p>\302\251 2026 ZyropFoodOrder. All rights reserved.</p>\n        <p className=\"hidden md:block\">Designed with Modern Corporate Aesthetics</p>\n      </div>\n    </footer>\n  );\n}\n"
