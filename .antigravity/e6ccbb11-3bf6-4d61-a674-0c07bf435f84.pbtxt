  file_change {
    absolute_path_uri: "file:///src/components/Navbar.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\nimport { Search, Bell, User, ShoppingBag, Menu, Home as HomeIcon, Receipt, Compass, SlidersHorizontal, MapPin, ChevronDown } from \'lucide-react\';\nimport { ScreenType } from \'../types\';\n\ninterface NavbarProps {\n  currentScreen: ScreenType;\n  onScreenChange: (screen: ScreenType) => void;\n  cartCount: number;\n  deliveryStatus: string;\n  onSearchChange?: (val: string) => void;\n  searchValue?: string;\n}\n\nexport default function Navbar({\n  currentScreen,\n  onScreenChange,\n  cartCount,\n  deliveryStatus,\n  onSearchChange,\n  searchValue = \'\'\n}: NavbarProps) {\n  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);\n\n  return (\n    <>\n      {/* DESKTOP HEADER (Visible on md and up) */}\n      <header className=\"bg-white border-b border-gray-100 sticky top-0 z-50 hidden md:block\">\n        <div className=\"max-w-[1280px] mx-auto px-10 h-20 flex justify-between items-center bg-white\">\n          <div className=\"flex items-center gap-12\">\n            {/* Logo */}\n            <span \n              onClick={() => onScreenChange(\'home\')}\n              className=\"text-2xl font-extrabold text-[#a83300] tracking-tight cursor-pointer font-sans\"\n            >\n              ZyropFoodOrder\n            </span>\n\n            {/* Desktop Search */}\n            <div className=\"flex items-center bg-[#f5f3f3] rounded-full px-5 py-2.5 gap-3 w-80 border border-transparent focus-within:border-[#e5beb2] focus-within:bg-white transition-all duration-200\">\n              <Search className=\"h-[18px] w-[18px] text-[#5f5e5e]\" />\n              <input \n                type=\"text\" \n                placeholder=\"Search for food, restaurants...\"\n                className=\"bg-transparent border-none outline-none focus:outline-none focus:ring-0 text-sm w-full text-[#1b1c1c] placeholder:text-[#5f5e5e]\"\n                value={searchValue}\n                onChange={(e) => onSearchChange?.(e.target.value)}\n              />\n            </div>\n          </div>\n\n          {/* Desktop Nav Links */}\n          <nav className=\"flex items-center gap-8 font-sans font-semibold text-sm\">\n            <button \n              onClick={() => onScreenChange(\'home\')}\n              className={`pb-1 transition-colors relative ${currentScreen === \'home\' ? \'text-[#a83300] border-b-2 border-[#a83300]\' : \'text-[#5f5e5e] hover:text-[#a83300]\'}`}\n            >\n              Browse\n            </button>\n            <button \n              onClick={() => onScreenChange(\'tracking\')}\n              className={`pb-1 transition-colors relative flex items-center gap-1.5 ${currentScreen === \'tracking\' ? \'text-[#a83300] border-b-2 border-[#a83300]\' : \'text-[#5f5e5e] hover:text-[#a83300]\'}`}\n            >\n              Orders\n              {deliveryStatus && (\n                <span className=\"w-2 h-2 bg-[#00c853] rounded-full animate-pulse inline-block\" />\n              )}\n            </button>\n            <a href=\"#offers\" className=\"pb-1 text-[#5f5e5e] hover:text-[#a83300] transition-colors\">\n              Offers\n            </a>\n            <a href=\"#partner\" className=\"pb-1 text-[#5f5e5e] hover:text-[#a83300] transition-colors\">\n              Partner\n            </a>\n            <a href=\"#admin\" className=\"pb-1 text-[#5f5e5e] hover:text-[#a83300] transition-colors font-semibold\">\n              Admin\n            </a>\n          </nav>\n\n          {/* User Controls */}\n          <div className=\"flex items-center gap-6\">\n            <div className=\"flex items-center gap-4 text-[#5c4037]\">\n              <button className=\"hover:bg-gray-100 p-2 rounded-full transition-colors relative group\">\n                <Bell className=\"h-[20px] w-[20px]\" />\n                <span className=\"absolute top-1 right-1 w-2 h-2 bg-[#a83300] rounded-full\" />\n              </button>\n              <button \n                onClick={() => alert(\"Simulated Profile Menu\")}\n                className=\"hover:bg-gray-100 p-2 rounded-full transition-colors\"\n              >\n                <User className=\"h-[20px] w-[20px]\" />\n              </button>\n            </div>\n            \n            <div className=\"h-8 w-[1.5px] bg-[#e5beb2]\"></div>\n\n            {/* Cart Button */}\n            <button \n              onClick={() => onScreenChange(\'cart\')}\n              className=\"bg-[#a83300] text-white px-6 py-2.5 rounded-full text-sm font-semibold hover:bg-[#d24200] active:scale-95 transition-all flex items-center gap-2 shadow-[0px_4px_12px_rgba(168,51,0,0.15)]\"\n            >\n              <ShoppingBag className=\"h-4 w-4\" />\n              <span>Cart</span>\n              {cartCount > 0 && (\n                <span className=\"bg-white text-[#a83300] rounded-full px-2 py-0.5 text-xs font-bold font-sans\">\n                  {cartCount}\n                </span>\n              )}\n            </button>\n          </div>\n        </div>\n      </header>\n\n      {/* MOBILE COMPACT HEADER (Visible below md) */}\n      <header className=\"bg-white border-b border-gray-100 sticky top-0 z-50 md:hidden flex justify-between items-center px-4 h-16 w-full\">\n        <div className=\"flex items-center gap-3\">\n          <button \n            onClick={() => setMobileMenuOpen(!mobileMenuOpen)}\n            className=\"p-1 rounded-full text-[#a83300] hover:bg-gray-50 active:scale-95 transition-transform\"\n          >\n            <Menu className=\"h-6 w-6\" />\n          </button>\n          <span \n            onClick={() => onScreenChange(\'home\')}\n            className=\"text-lg font-extrabold text-[#a83300] tracking-tight cursor-pointer\"\n          >\n            ZyropFoodOrder\n          </span>\n        </div>\n\n        <div className=\"flex items-center gap-1.5\">\n          {/* Notification / Cart quick button */}\n          <button \n            onClick={() => onScreenChange(\'cart\')}\n            className=\"relative p-2 text-[#a83300] hover:bg-gray-50 rounded-full\"\n          >\n            <ShoppingBag className=\"h-5 w-5\" />\n            {cartCount > 0 && (\n              <span className=\"absolute top-1.5 right-1.5 bg-[#d24200] text-white rounded-full w-4.5 h-4.5 text-[10px] flex items-center justify-center font-bold font-sans border-2 border-white\">\n                {cartCount}\n              </span>\n            )}\n          </button>\n        </div>\n      </header>\n\n      {/* MOBILE LEFT OVERLAY DRAWER */}\n      {mobileMenuOpen && (\n        <div className=\"fixed inset-0 z-50 md:hidden flex\">\n          {/* Backdrop */}\n          <div \n            onClick={() => setMobileMenuOpen(false)}\n            className=\"fixed inset-0 bg-black/40 backdrop-blur-sm transition-opacity duration-300\"\n          />\n          {/* Drawer Panel */}\n          <div className=\"relative w-72 max-w-xs bg-white h-full shadow-2xl flex flex-col p-6 animate-slide-right\">\n            <div className=\"flex justify-between items-center mb-8 border-b border-gray-100 pb-4\">\n              <span className=\"text-xl font-extrabold text-[#a83300]\">ZyropFoodOrder</span>\n              <button \n                onClick={() => setMobileMenuOpen(false)}\n                className=\"text-gray-400 text-xs font-semibold hover:text-black\"\n              >\n                Close\n              </button>\n            </div>\n            \n            <div className=\"space-y-5 flex-1 font-sans font-medium text-sm text-[#1b1c1c]\">\n              <button \n                onClick={() => { onScreenChange(\'home\'); setMobileMenuOpen(false); }}\n                className={`w-full text-left py-2.5 px-3 rounded-lg transition-colors flex items-center gap-3 ${currentScreen === \'home\' ? \'bg-[#ffdbd0] text-[#a83300]\' : \'hover:bg-gray-50\'}`}\n              >\n                <Compass className=\"h-5 w-5\" />\n                Browse Foods\n              </button>\n              <button \n                onClick={() => { onScreenChange(\'tracking\'); setMobileMenuOpen(false); }}\n                className={`w-full text-left py-2.5 px-3 rounded-lg transition-colors flex items-center gap-3 ${currentScreen === \'tracking\' ? \'bg-[#ffdbd0] text-[#a83300]\' : \'hover:bg-gray-50\'}`}\n              >\n                <Receipt className=\"h-5 w-5\" />\n                Live Tracking\n                {deliveryStatus && (\n                  <span className=\"ml-auto w-2 h-2 bg-[#00c853] rounded-full animate-pulse\" />\n                )}\n              </button>\n              <button \n                onClick={() => { onScreenChange(\'cart\'); setMobileMenuOpen(false); }}\n                className={`w-full text-left py-2.5 px-3 rounded-lg transition-colors flex items-center gap-3 ${currentScreen === \'cart\' ? \'bg-[#ffdbd0] text-[#a83300]\' : \'hover:bg-gray-50\'}`}\n              >\n                <ShoppingBag className=\"h-5 w-5\" />\n                Your Shopping Cart\n                {cartCount > 0 && (\n                  <span className=\"ml-auto bg-[#a83300] text-white text-xs font-bold px-2 py-0.5 rounded-full\">{cartCount}</span>\n                )}\n              </button>\n            </div>\n\n            <div className=\"border-t border-gray-100 pt-6 text-xs text-gray-400 font-sans\">\n              <p className=\"font-semibold mb-1\">ZyropFoodOrder Prototype v1.0</p>\n              <p>\302\251 2026 ZyropFoodOrder. All rights reserved.</p>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* MOBILE BOTTOM NAVIGATION BAR (Visible below md) */}\n      <nav className=\"fixed bottom-0 left-0 w-full z-40 flex justify-around items-center py-2.5 px-2 bg-white shadow-[0px_-2px_12px_rgba(0,0,0,0.06)] rounded-t-2xl md:hidden border-t border-gray-100\">\n        <button \n          onClick={() => onScreenChange(\'home\')}\n          className={`flex flex-col items-center justify-center p-2 rounded-xl transition-all ${currentScreen === \'home\' ? \'text-[#a83300]\' : \'text-[#5f5e5e] hover:text-[#a83300]\'}`}\n        >\n          <HomeIcon className=\"h-5 w-5\" />\n          <span className=\"text-[10px] font-semibold font-sans mt-1\">Home</span>\n        </button>\n\n        <button \n          onClick={() => onScreenChange(\'cart\')}\n          className={`flex flex-col items-center justify-center p-2 rounded-xl transition-all relative ${currentScreen === \'cart\' ? \'text-[#a83300]\' : \'text-[#5f5e5e] hover:text-[#a83300]\'}`}\n        >\n          <ShoppingBag className=\"h-5 w-5\" />\n          <span className=\"text-[10px] font-semibold font-sans mt-1\">Cart</span>\n          {cartCount > 0 && (\n            <span className=\"absolute top-1.5 right-2 bg-[#d24200] text-white rounded-full w-4 h-4 text-[9px] flex items-center justify-center font-bold\">\n              {cartCount}\n            </span>\n          )}\n        </button>\n\n        <button \n          onClick={() => onScreenChange(\'tracking\')}\n          className={`flex flex-col items-center justify-center p-2 rounded-xl transition-all relative ${currentScreen === \'tracking\' ? \'text-[#a83300]\' : \'text-[#5f5e5e] hover:text-[#a83300]\'}`}\n        >\n          <Receipt className=\"h-5 w-5\" />\n          <span className=\"text-[10px] font-semibold font-sans mt-1\">Orders</span>\n          {deliveryStatus && (\n            <span className=\"absolute top-2.5 right-3.5 w-1.5 h-1.5 bg-[#00c853] rounded-full animate-ping\" />\n          )}\n        </button>\n\n        <button \n          onClick={() => alert(\"Prototyped Account Page\")}\n          className=\"flex flex-col items-center justify-center p-2 rounded-xl text-[#5f5e5e] hover:text-[#a83300] transition-all\"\n        >\n          <User className=\"h-5 w-5\" />\n          <span className=\"text-[10px] font-semibold font-sans mt-1\">Profile</span>\n        </button>\n      </nav>\n    </>\n  );\n}\n"
