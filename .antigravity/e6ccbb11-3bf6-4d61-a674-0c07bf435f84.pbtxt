    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect } from \'react\';\nimport Navbar from \'./components/Navbar\';\nimport Footer from \'./components/Footer\';\nimport CustomerHome from \'./components/CustomerHome\';\nimport CartScreen from \'./components/CartScreen\';\nimport OrderTracking from \'./components/OrderTracking\';\nimport { ScreenType, CartItem, ActiveOrder, MenuItem, Restaurant, TrackingStep } from \'./types\';\n\nexport default function App() {\n  const [currentScreen, setCurrentScreen] = useState<ScreenType>(\'home\');\n  const [cartItems, setCartItems] = useState<CartItem[]>([]);\n  const [activeOrder, setActiveOrder] = useState<ActiveOrder | null>(null);\n  const [searchValue, setSearchValue] = useState<string>(\'\');\n\n  // Scroll to top upon screen navigation\n  useEffect(() => {\n    window.scrollTo({ top: 0, behavior: \'smooth\' });\n  }, [currentScreen]);\n\n  // Handle adding an item to the shopping cart\n  const handleAddToCart = (item: MenuItem, restaurant: Restaurant, customization?: string) => {\n    setCartItems(prev => {\n      // Look for duplicate item with identical customization options in the current cart\n      const existingIdx = prev.findIndex(\n        c => c.menuItem.id === item.id && c.customization === customization\n      );\n\n      if (existingIdx > -1) {\n        const copied = [...prev];\n        copied[existingIdx].quantity += 1;\n        return copied;\n      } else {\n        const newItem: CartItem = {\n          id: `${item.id}_${customization || \'plain\'}_${Date.now()}`,\n          menuItem: item,\n          restaurantId: restaurant.id,\n          restaurantName: restaurant.name,\n          quantity: 1,\n          customization\n        };\n        return [...prev, newItem];\n      }\n    });\n  };\n\n  // Modify cart quantity\n  const handleUpdateQuantity = (id: string, delta: number) => {\n    setCartItems(prev => {\n      return prev.map(item => {\n        if (item.id === id) {\n          const updatedQty = item.quantity + delta;\n          return { ...item, quantity: Math.max(1, updatedQty) };\n        }\n        return item;\n      }).filter(item => item.quantity > 0);\n    });\n  };\n\n  // Completely wipe an item from the cart\n  const handleRemoveItem = (id: string) => {\n    setCartItems(prev => prev.filter(c => c.id !== id));\n  };\n\n  // Triggered when clicking \'PLACE ORDER\' in the checkout dashboard\n  const handlePlaceOrder = (paymentMethod: string, address: string, deliveryFee: number) => {\n    if (cartItems.length === 0) return;\n\n    // Compile active order descriptors\n    const subtotal = cartItems.reduce((acc, c) => acc + (c.menuItem.price * c.quantity), 0);\n    const taxes = 1.45;\n    const total = subtotal + deliveryFee + taxes;\n\n    const newOrder: ActiveOrder = {\n      id: `#ZY-${Math.floor(1000 + Math.random() * 9000)}`,\n      restaurantName: cartItems[0].restaurantName,\n      items: cartItems.map(c => ({\n        name: c.menuItem.name,\n        quantity: c.quantity,\n        price: c.menuItem.price\n      })),\n      subtotal,\n      deliveryFee,\n      taxes,\n      total,\n      estArrival: \'12:45 PM\',\n      agent: {\n        name: \'Marcus Rodriguez\',\n        rating: \'4.9\',\n        deliveries: \'2k+ deliveries\',\n        image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuB8N79NnzBkNjJlH_j1MDJj1is3ZLHe5zf4QNLtwbxOQq9elB6w1-Eq8iK8QPl_kecxA_EkIvhpm8OgWEd4ajqCgMGzg6E-hsv5yjY-_3geRtReum09madJb2FykVO-iBptXyO0aAo7QKeUi_6V3VGDQHR_-IvGjgdbC6S_F7Nn3-nU5Cndtj6Oa_nD4-OhDUQvWly8lPVokasK_Cutr4tewAcOGRELa8H2W5TiFlz-XitgBe7vNL4pPys9N4ZRNJm_xGddPR209i4\',\n        phone: \'+1 (555) 902-1822\'\n      },\n      steps: [\n        { title: \'Order Placed\', time: \'12:10 PM\', description: \'Order was acknowledged\', status: \'completed\' },\n        { title: \'Preparing your meal\', time: \'12:15 PM\', description: \'Fresh culinary work in kitchen\', status: \'completed\' },\n        { title: \'Out for Delivery\', time: \'12:25 PM\', description: \'Your agent is 2.4km away\', status: \'active\' },\n        { title: \'Order Delivered\', time: \'12:45 PM\', description: \'Expected at door\', status: \'upcoming\' }\n      ],\n      currentStepIndex: 2\n    };\n\n    setActiveOrder(newOrder);\n    setCartItems([]); // Reset customer cart basket\n    setCurrentScreen(\'tracking\'); // Navigate straight to tracker\n  };\n\n  // Compute total count of items in the cart\n  const cartIconCount = cartItems.reduce((acc, c) => acc + c.quantity, 0);\n\n  return (\n    <div className=\"min-h-screen bg-[#fbf9f8] flex flex-col justify-between font-sans selection:bg-[#ffdbd0]\">\n      {/* Upper Navigation section */}\n      <Navbar \n        currentScreen={currentScreen} \n        onScreenChange={setCurrentScreen} \n        cartCount={cartIconCount}\n        deliveryStatus={activeOrder ? \'Delivering\' : \'\'}\n        searchValue={searchValue}\n        onSearchChange={setSearchValue}\n      />\n\n      {/* Main viewport panels */}\n      <main className=\"flex-1 pb-16 md:pb-8\">\n        {currentScreen === \'home\' && (\n          <CustomerHome \n            onAddToCart={handleAddToCart} \n            onScreenChange={setCurrentScreen}\n            cartCount={cartIconCount}\n            searchValue={searchValue}\n          />\n        )}\n\n        {currentScreen === \'cart\' && (\n          <CartScreen \n            cartItems={cartItems}\n            onUpdateQuantity={handleUpdateQuantity}\n            onRemoveItem={handleRemoveItem}\n            onPlaceOrder={handlePlaceOrder}\n            onScreenChange={setCurrentScreen}\n          />\n        )}\n\n        {currentScreen === \'tracking\' && (\n          <OrderTracking \n            activeOrder={activeOrder}\n            onScreenChange={setCurrentScreen}\n          />\n        )}\n      </main>\n\n      {/* Lower Footer brand block */}\n      <Footer />\n    </div>\n  );\n}\n"
    }
